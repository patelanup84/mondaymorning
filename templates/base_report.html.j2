<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ report_title }}{% endblock %}</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- DataTables CSS -->
    <link href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    
    <!-- Custom Report Styles -->
    <style>
        .report-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 2rem 0;
            margin-bottom: 2rem;
        }
        
        .metric-card {
            border: none;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            transition: box-shadow 0.15s ease-in-out;
        }
        
        .metric-card:hover {
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }
        
        .metric-value {
            font-size: 1.75rem;
            font-weight: 600;
            color: #495057;
        }
        
        .metric-label {
            font-size: 0.875rem;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .competitive-context {
            font-size: 0.75rem;
            color: #6c757d;
            margin-top: 0.25rem;
        }
        
        .our-position {
            font-size: 0.75rem;
            color: #0d6efd;
            font-weight: 500;
            margin-top: 0.25rem;
        }
        
        .table-section {
            margin: 3rem 0;
        }
        
        .section-title {
            color: #495057;
            font-weight: 600;
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #e9ecef;
        }
        
        .rank-badge {
            font-size: 0.75rem;
            padding: 0.25em 0.5em;
        }
        
        .delta-positive {
            color: #dc3545;
        }
        
        .delta-negative {
            color: #198754;
        }
        
        .delta-neutral {
            color: #6c757d;
        }
        
        @media print {
            .report-header {
                background: #667eea !important;
                -webkit-print-color-adjust: exact;
            }
        }
    </style>
    
    {% block extra_head %}{% endblock %}
</head>
<body>
    <!-- Report Header -->
    <div class="report-header">
        <div class="container">
            <div class="row">
                <div class="col-md-8">
                    <h1 class="mb-2">{% block header_title %}{{ report_title }}{% endblock %}</h1>
                    <p class="mb-0 opacity-75">{% block header_subtitle %}Competitive Intelligence Report{% endblock %}</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <p class="mb-0">
                        <small>Generated on<br>{{ generated_at }}</small>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container">
        {% block content %}{% endblock %}
    </div>

    <!-- Footer -->
    <footer class="text-center text-muted py-4 mt-5">
        <div class="container">
            <hr class="mb-4">
            <small>MondayMorning Competitive Intelligence Platform</small>
        </div>
    </footer>

    <!-- Bootstrap 5 JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- jQuery (required for DataTables) -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    
    <!-- DataTables JavaScript -->
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    
    {% block extra_scripts %}{% endblock %}
</body>
</html>